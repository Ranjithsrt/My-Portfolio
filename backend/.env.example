PORT=5000
MONGODB_URI=mongodb://localhost:27017/myPortfolio
NODE_ENV=development

# Frontend URL for CORS (add your Vercel frontend URL in production)
FRONTEND_URL=

# Gemini API Key (Get free key from https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Email Configuration (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Portfolio <noreply@portfolio.com>
NOTIFICATION_EMAIL=your-destination-email@gmail.com


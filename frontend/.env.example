# Frontend Environment Variables
# Copy this to .env and fill in your values for local development
# For Vercel deployment, add these in Project Settings > Environment Variables

# Backend API URL (required)
# Use your Vercel backend URL for production, localhost for development
VITE_API_URL=http://localhost:5000/api

# Example for production:
# VITE_API_URL=https://your-backend.vercel.app/api
